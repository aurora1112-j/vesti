{
  "name": "@vesti/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && pnpm --dir ../../frontend exec esbuild ../packages/vesti-ui/src/index.ts --bundle --format=esm --platform=browser --target=es2020 --jsx=automatic --tsconfig=../packages/vesti-ui/tsconfig.build.json --outfile=../packages/vesti-ui/dist/index.js --external:react --external:react-dom --external:react/jsx-runtime --external:react/jsx-dev-runtime --external:lucide-react --external:marked --external:dompurify --external:echarts"
  },
  "peerDependencies": {
    "lucide-react": ">=0.5.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "dompurify": "^3.3.1",
    "echarts": "^6.0.0",
    "marked": "^17.0.3"
  }
}
